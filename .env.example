# Copy to .env and fill in. Keyless feeds need nothing:
# Open-Meteo (weather), World Bank (world data), CoinGecko (crypto), ECB FX.

# Market & macro data
# FRED — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# Alpha Vantage — https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=

# Optional capability keys (feature-gated; each behind its own adapter)
# Google Gemini — optional AI insights/summaries
GEMINI_API_KEY=
# ElevenLabs — optional voice briefings / TTS
ELEVENLABS_API_KEY=
# Tavily — AI search for company news/research
TAVILY_API_KEY=

# Copy to .env and fill in. Keyless feeds need nothing:
# Open-Meteo (weather), World Bank (world data), CoinGecko (crypto), ECB FX.

# --- Market & macro data ---
FRED_API_KEY=          # https://fred.stlouisfed.org/docs/api/api_key.html
ALPHAVANTAGE_API_KEY=  # https://www.alphavantage.co/support/#api-key

# --- Optional capability keys (feature-gated; each behind its own adapter) ---
GEMINI_API_KEY=        # Google Gemini — optional AI insights/summaries
ELEVENLABS_API_KEY=    # ElevenLabs — optional voice briefings / TTS
TAVILY_API_KEY=        # Tavily — AI search for company news/research
